# FogMirror Backend 环境变量示例
# 复制为 backend/.env（已在 .gitignore）

# Server
PORT=3001
NODE_ENV=development

# MongoDB (必填)
# 本地：mongodb://localhost:27017/fogmirror
# Atlas：mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/fogmirror?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/fogmirror

# AI 服务选择
# Options: siliconflow | openrouter | openai | gemini | mock-vision
AI_SERVICE_TYPE=siliconflow

# SiliconFlow (推荐)
SILICONFLOW_API_KEY=your_siliconflow_key_here
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V2.5

# OpenRouter (替代)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openai/chatgpt-4o-latest

# OpenAI (直连)
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Gemini
GEMINI_API_KEY=your_gemini_key_here

# JWT (必填)
# 生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_random_32byte_hex
JWT_EXPIRE=7d

# CORS
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# File Upload
MAX_FILE_SIZE=10485760
