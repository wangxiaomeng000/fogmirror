# FogMirror 雾镜 - 环境变量示例
# 复制本文件为 .env.local（开发）或在 Vercel Dashboard 配置（部署）
# .env.local 已在 .gitignore，绝不会被提交

# ============================================================
# 前端（Next.js）
# ============================================================

# 后端 API 入口。本地开发用 backend Express → http://localhost:3001/api
# 部署到 Vercel 时如果使用 pages/api/ 路由请保持空（默认走相对路径 /api）
# 如果后端独立部署（如 Railway / Render）填外部 URL：https://api.yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ============================================================
# 后端（backend/.env 也用同一组变量；部署到 Vercel 时直接设在 Vercel Dashboard）
# ============================================================

# Server
PORT=3001
NODE_ENV=development

# MongoDB (必填)
# 本地：mongodb://localhost:27017/fogmirror
# 云端：mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/fogmirror?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/fogmirror

# JWT (必填，32+ 位随机字符串)
# 生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_random_32byte_hex
JWT_EXPIRE=7d

# CORS
FRONTEND_URL=http://localhost:3000

# ============================================================
# AI 服务（任选一种，AI_SERVICE_TYPE 切换）
# ============================================================

# 选择服务：siliconflow | openrouter | openai | gemini | mock-vision
AI_SERVICE_TYPE=siliconflow

# SiliconFlow（默认推荐，国内可用，支持 vision）
# 申请：https://siliconflow.cn → 控制台 → API 密钥
SILICONFLOW_API_KEY=your_siliconflow_key_here
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V2.5

# OpenRouter（替代方案，支持 GPT-4 等）
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openai/chatgpt-4o-latest

# OpenAI（直连）
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=your_gemini_key_here

# ============================================================
# 杂项
# ============================================================

RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
MAX_FILE_SIZE=10485760
